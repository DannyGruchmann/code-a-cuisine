rules_version = '2';

// Security rules for Code A Cuisine.
//
// The n8n backend writes to Firestore using an OAuth2 service credential,
// which bypasses these rules entirely. Therefore these rules only constrain
// the anonymous web client and can be locked down hard without breaking the
// recipe-generation workflow. This is what prevents quota tampering (and the
// resulting runaway AI/Gemini costs) and stops enumeration of other users'
// requests.
service cloud.firestore {
  match /databases/{database}/documents {

    function onlyChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isNewRequest() {
      return request.resource.data.status == 'pending'
        && request.resource.data.payload is map;
    }

    // Public recipe library: anyone may read. Web clients may update only the
    // "hearts" like counter. Recipes themselves are created/deleted solely by
    // the n8n backend (via privileged OAuth, which bypasses these rules).
    match /recipes/{recipeId} {
      allow get, list: if true;
      allow update: if onlyChanged(['hearts']);
      allow create, delete: if false;
    }

    // Anonymous recipe-generation requests. Document IDs are unguessable
    // random Firestore IDs, so single-document reads are allowed but listing
    // (enumeration) is not. Clients may only flip the request into an error
    // state; results are written exclusively by the n8n backend.
    match /recipeRequests/{requestId} {
      allow get: if true;
      allow list: if false;
      allow create: if isNewRequest();
      allow update: if onlyChanged(['status', 'errorMessage', 'updatedAt']);
      allow delete: if false;
    }

    // IP and global quota counters are managed exclusively by the n8n backend.
    // No web client may ever read or write them — this is the core protection
    // against quota bypass and runaway AI costs.
    match /quotaIpDaily/{docId} {
      allow read, write: if false;
    }
    match /quotaGlobalDaily/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
